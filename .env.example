# Environment Variables for HH Applicant Tool (issue #49)
#
# Copy this file to .env and fill in your values.
# This file is gitignored and should not be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker compose --env-file .env up -d

# =============================================================================
# HH Search Profile (Required)
# =============================================================================
# HH Profile ID from hh.ru (found in URL when viewing your profile)
HH_PROFILE_ID=default

# Resume ID to use for applications (found in URL when viewing your resume on hh.ru)
RESUME_ID=

# =============================================================================
# Telegram Bot (Optional - for draft review workflow)
# =============================================================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated list of user IDs allowed to use the bot
# Get your user ID from @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=

# =============================================================================
# OpenAI / AI Services (Optional - for AI features)
# =============================================================================
# OpenAI API Key for cover letter generation, vacancy filtering, captcha solving
OPENAI_API_KEY=

# Optional: Custom OpenAI base URL (for compatible APIs like Azure, local models)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Database (Optional - for PostgreSQL)
# =============================================================================
# PostgreSQL connection URL (used when --profile postgres is enabled)
# Format: postgresql://user:password@host:port/database
# Default uses SQLite: sqlite:///app/config/hh_applicant_tool.db
DATABASE_URL=sqlite:///app/config/hh_applicant_tool.db

# PostgreSQL individual settings (used by postgres service)
POSTGRES_DB=hh_applicant_tool
POSTGRES_USER=hh_user
POSTGRES_PASSWORD=hh_password

# =============================================================================
# Redis (Optional - for caching and queue)
# =============================================================================
# Redis connection URL
# Default: redis://redis:6379/0 (when --profile redis is enabled)
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Email / SMTP (Optional - for sending emails on application)
# =============================================================================
# SMTP server host (default: mailhog for local dev)
SMTP_HOST=mailhog

# SMTP server port (default: 1025 for MailHog, 587 for TLS, 465 for SSL)
SMTP_PORT=1025

# SMTP username (if required)
SMTP_USER=

# SMTP password (if required)
SMTP_PASSWORD=

# Use SSL/TLS (true/false)
SMTP_SSL=false

# From email address
SMTP_FROM=noreply@localhost

# Email subject template for applications
APPLY_MAIL_SUBJECT=Отклик на вакансию: {vacancy_name}

# Email body template for applications (supports {vacancy_name}, {vacancy_url}, {employer_name})
APPLY_MAIL_BODY=Автоматический отклик на вакансию "{vacancy_name}" ({vacancy_url}) от работодателя {employer_name}.

# =============================================================================
# MinIO / S3 (Optional - for file storage)
# =============================================================================
# MinIO endpoint (default: minio:9000 when --profile minio is enabled)
MINIO_ENDPOINT=minio:9000

# MinIO access key (default: minioadmin)
MINIO_ACCESS_KEY=minioadmin

# MinIO secret key (default: minioadmin)
MINIO_SECRET_KEY=minioadmin

# MinIO bucket name
MINIO_BUCKET=hh-applicant-tool

# Use HTTPS for MinIO (true/false)
MINIO_SECURE=false

# =============================================================================
# General Settings
# =============================================================================
# Config directory inside container
CONFIG_DIR=/app/config

# Timezone (uncomment if server time differs from your timezone)
# TZ=Europe/Moscow

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Python settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Terminal type for colored output
TERM=xterm
